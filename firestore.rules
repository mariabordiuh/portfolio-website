// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: projects
// Fields:
//   - title: string (required)
//   - pillar: string (required) - one of ['AI Generated', 'Animations & Motion', 'Illustration & Design', 'Art Direction']
//   - category: string (required)
//   - subCategory: string
//   - description: string
//   - thumbnail: string
//   - images: list[string]
//   - videoUrl: string
//   - tools: list[string]
//   - client: string
//   - globalContext: string
//   - creativeTension: string
//   - mariaRole: list[string]
//   - moodboardImages: list[string]
//   - explorationType: string
//   - explorationImages: list[string]
//   - explorationVideos: list[string]
//   - explorationCaption: string
//   - decisionMomentCopy: string
//   - colorSystem: list[map]
//   - animaticVideoUrl: string
//   - animaticCaption: string
//   - hybridizationImages: list[string]
//   - hybridizationCaption: string
//   - outcomeVisuals: list[string]
//   - outcomeResultCopy: string
//   - updatedAt: timestamp
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "helloveo333@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasValidStatus(data) {
      return ('status' in data) && data.status in ['draft', 'published'];
    }

    function isDraft(data) {
      return ('status' in data) && data.status == 'draft';
    }

    function isValidProject(data) {
      return hasValidStatus(data) &&
             data.pillar in ['AI Generated', 'Animation & Motion', 'Illustration & Design', 'Art Direction'] &&
             (isDraft(data)
               ? (!('title' in data) || (data.title is string && data.title.size() < 200))
               : (data.title is string && data.title.size() > 0 && data.title.size() < 200)) &&
             (isDraft(data)
               ? (!('category' in data) || (data.category is string && data.category.size() < 100))
               : (data.category is string && data.category.size() < 100)) &&
             (!('description' in data) || (data.description is string && data.description.size() < 5000)) &&
             (!('thumbnail' in data) || (data.thumbnail is string && data.thumbnail.size() < 1000));
    }

    function isValidVideo(data) {
      return hasValidStatus(data) &&
             (isDraft(data)
               ? (!('url' in data) || data.url is string)
               : (data.url is string && data.url.size() > 0)) &&
             (!('title' in data) || data.title is string) &&
             (!('description' in data) || data.description is string) &&
             (!('thumbnail' in data) || data.thumbnail is string) &&
             (!('pillar' in data) || data.pillar is string) &&
             (!('subCategory' in data) || data.subCategory is string);
    }

    function isValidLabItem(data) {
      return hasValidStatus(data) &&
             (isDraft(data)
               ? (!('title' in data) || data.title is string)
               : (data.title is string && data.title.size() > 0)) &&
             (!('type' in data) || data.type in ['Experiment', 'Learning', 'AI', 'Vibe', 'Thoughts']) &&
             (isDraft(data)
               ? (!('content' in data) || data.content is string)
               : (data.content is string && data.content.size() > 0));
    }

    function isValidGalleryImage(data) {
      return hasValidStatus(data) &&
             (isDraft(data)
               ? (!('url' in data) || data.url is string)
               : (data.url is string && data.url.size() > 0)) &&
             (!('tags' in data) || data.tags is list);
    }

    function isValidHomeHeroSettings(data) {
      return data.mode in ['image', 'video'] &&
             data.desktopImage is string &&
             data.desktopImage.size() > 0 &&
             (!('mobileImage' in data) || data.mobileImage is string) &&
             (!('desktopVideo' in data) || data.desktopVideo is string) &&
             (!('mobileVideo' in data) || data.mobileVideo is string) &&
             (!('posterImage' in data) || data.posterImage is string);
    }

    // Public lead form on /ai. Create-only, exact keys, bounded sizes,
    // server timestamp enforced — nothing readable or editable from the client.
    function isValidAiLead(data) {
      return data.keys().hasOnly(['name', 'email', 'product', 'identity', 'lang', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.email is string && data.email.size() > 3 && data.email.size() < 320 &&
             data.product is string && data.product.size() > 0 && data.product.size() < 2000 &&
             data.identity is string && data.identity.size() < 100 &&
             data.lang in ['en', 'de'] &&
             data.createdAt == request.time;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /projects/{projectId} {
      allow read: if isAdmin() || resource.data.status == 'published';
      allow create: if isAdmin() && isValidProject(request.resource.data);
      allow update: if isAdmin() && isValidProject(request.resource.data);
      allow delete: if isAdmin();
    }

    match /videos/{videoId} {
      allow read: if isAdmin() || resource.data.status == 'published';
      allow create: if isAdmin() && isValidVideo(request.resource.data);
      allow update: if isAdmin() && isValidVideo(request.resource.data);
      allow delete: if isAdmin();
    }

    match /labItems/{itemId} {
      allow read: if isAdmin() || resource.data.status == 'published';
      allow create: if isAdmin() && isValidLabItem(request.resource.data);
      allow update: if isAdmin() && isValidLabItem(request.resource.data);
      allow delete: if isAdmin();
    }

    match /gallery/{imageId} {
      allow read: if isAdmin() || resource.data.status == 'published';
      allow create: if isAdmin() && isValidGalleryImage(request.resource.data);
      allow update: if isAdmin() && isValidGalleryImage(request.resource.data);
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if isAdmin() || settingId == 'homeHero';
      allow create, update: if isAdmin() &&
        settingId == 'homeHero' &&
        isValidHomeHeroSettings(request.resource.data);
      allow delete: if false;
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAdmin();
    }

    match /omrVisits/{visitId} {
      allow read, write: if false;
    }

    match /aiLeads/{leadId} {
      allow read: if isAdmin();
      allow create: if isValidAiLead(request.resource.data);
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
