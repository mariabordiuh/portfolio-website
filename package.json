{
  "name": "maria-bordiuh-portfolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build && node scripts/generate-route-meta.mjs",
    "analyze": "ANALYZE=true vite build",
    "analyze:open": "ANALYZE=true vite build && open dist/bundle-analysis.html",
    "preview": "vite preview --host 0.0.0.0",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src vite.config.ts eslint.config.js",
    "check": "npm run lint && npm run typecheck && npm run build",
    "hosting:preview": "npm run build && npx --yes firebase-tools hosting:channel:deploy preview",
    "hosting:preview:construction": "VITE_UNDER_CONSTRUCTION=true npm run build && node scripts/prepare-construction-index.mjs && npx --yes firebase-tools hosting:channel:deploy construction",
    "hosting:deploy": "npm run build && npx --yes firebase-tools deploy --only hosting,firestore,storage",
    "hosting:deploy:construction": "VITE_UNDER_CONSTRUCTION=true npm run build && node scripts/prepare-construction-index.mjs && npx --yes firebase-tools deploy --only hosting",
    "seed": "npx vite-node scripts/seed-projects.ts"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@firecms/neat": "^0.8.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "firebase": "^12.13.0",
    "lenis": "^1.3.23",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.1",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.60.1",
    "vite": "^6.2.0"
  }
}
