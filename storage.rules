rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null &&
             request.auth.token.email == "helloveo333@gmail.com" &&
             request.auth.token.email_verified == true;
    }

    match /projects/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /videos/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /gallery/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /lab/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /hero/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /thumbnails/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}
